import React, { useState, useMemo, useRef } from 'react';
import { View, Text, TouchableOpacity, FlatList, Image, ScrollView, Dimensions, TextInput } from 'react-native';
import { getStyles } from '../styles';
import { cardImages } from '../data/cardDatabase';
import { COLOR_TRANSLATION_MAP } from '../constants';

const EXCLUDED_TYPES = ['RESOURCE', 'EX BASE', 'EX RESOURCE'];

const DeckBuilder = ({ 
  filteredCards, language, isDarkMode, isMobile, screenWidth,
  onClose, cardsData
}) => {
  const styles = getStyles(isDarkMode);
  
  // ====== Deck State ======
  // Map<displayId, { card, count }> — 異畫/重印/Beta 全歸算到 displayId
  const [deckMap, setDeckMap] = useState(new Map());
  const [validationEnabled, setValidationEnabled] = useState(true);
  const [showExport, setShowExport] = useState(false);
  const exportRef = useRef(null);
  const [searchText, setSearchText] = useState('');

  // ====== Derived State ======
  const deckEntries = useMemo(() => Array.from(deckMap.values()), [deckMap]);
  const totalCards = useMemo(() => deckEntries.reduce((sum, e) => sum + e.count, 0), [deckEntries]);
  
  const colorsInDeck = useMemo(() => {
    const colors = new Set();
    deckEntries.forEach(e => {
      if (e.card.color && !['', '-'].includes(e.card.color)) colors.add(e.card.color);
    });
    return Array.from(colors);
  }, [deckEntries]);

  // ====== Validation ======
  const violations = useMemo(() => {
    if (!validationEnabled) return [];
    const v = [];
    if (totalCards > 50) v.push(`卡牌數量超過上限 (${totalCards}/50)`);
    if (colorsInDeck.length > 2) v.push(`顏色超過2色 (${colorsInDeck.map(c => COLOR_TRANSLATION_MAP[c] || c).join('、')})`);
    deckEntries.forEach(e => {
      if (e.count > 4) v.push(`「${e.card[`name_${language}`] || e.card.displayId}」超過4張 (${e.count}張)`);
    });
    return v;
  }, [validationEnabled, totalCards, colorsInDeck, deckEntries, language]);

  // ====== Card Pool (exclude resource/EX types) ======
  const availableCards = useMemo(() => {
    let cards = filteredCards.filter(c => !EXCLUDED_TYPES.includes(c.type));
    // De-dupe: only show one version per displayId for cleaner browsing
    // But still allow clicking any version
    if (searchText.trim()) {
      const q = searchText.trim().toLowerCase();
      cards = cards.filter(c => {
        const name = (c[`name_${language}`] || '').toLowerCase();
        const id = (c.displayId || c.id || '').toLowerCase();
        return name.includes(q) || id.includes(q);
      });
    }
    return cards;
  }, [filteredCards, searchText, language]);

  // ====== Actions ======
  const addCard = (card) => {
    const key = card.displayId || card.id;
    const newMap = new Map(deckMap);
    const existing = newMap.get(key);
    if (existing) {
      if (validationEnabled && existing.count >= 4) return; // Block at 4
      if (validationEnabled && totalCards >= 50) return; // Block at 50
      newMap.set(key, { card: existing.card, count: existing.count + 1 });
    } else {
      if (validationEnabled && totalCards >= 50) return;
      // Color check (only when validation on)
      if (validationEnabled && colorsInDeck.length >= 2 && card.color && !colorsInDeck.includes(card.color) && card.color !== '-' && card.color !== '') return;
      newMap.set(key, { card, count: 1 });
    }
    setDeckMap(newMap);
  };

  const removeCard = (displayId) => {
    const newMap = new Map(deckMap);
    const existing = newMap.get(displayId);
    if (existing) {
      if (existing.count > 1) {
        newMap.set(displayId, { card: existing.card, count: existing.count - 1 });
      } else {
        newMap.delete(displayId);
      }
    }
    setDeckMap(newMap);
  };

  const removeAll = (displayId) => {
    const newMap = new Map(deckMap);
    newMap.delete(displayId);
    setDeckMap(newMap);
  };

  const clearDeck = () => setDeckMap(new Map());

  // ====== Export / Screenshot ======
  const handleExport = async () => {
    setShowExport(true);
    // Wait for render
    setTimeout(async () => {
      try {
        const html2canvas = (await import('html2canvas')).default;
        const el = document.getElementById('deck-export-area');
        if (!el) return;
        const canvas = await html2canvas(el, { 
          backgroundColor: isDarkMode ? '#0f172a' : '#ffffff',
          scale: 2,
          useCORS: true,
        });
        const link = document.createElement('a');
        link.download = `GCG_Deck_${new Date().toISOString().slice(0,10)}.png`;
        link.href = canvas.toDataURL();
        link.click();
      } catch (err) {
        console.error('Export failed:', err);
      }
      setShowExport(false);
    }, 300);
  };

  // ====== Layout ======
  const isWide = screenWidth > 900;
  const poolColumns = isMobile ? 3 : Math.max(2, Math.floor((isWide ? screenWidth * 0.55 : screenWidth) / 180));
  const poolCardWidth = isMobile ? (screenWidth - 30) / 3 - 8 : 160;
  const deckCardSize = isMobile ? 70 : 90;

  // ====== Color indicators ======
  const colorEmoji = { Blue: '🔵', Green: '🟢', Red: '🔴', Purple: '🟣', White: '⚪' };

  // ====== Sorted deck for display ======
  const sortedDeck = useMemo(() => {
    return deckEntries.sort((a, b) => {
      const typeOrder = { UNIT: 0, PILOT: 1, COMMAND: 2, BASE: 3 };
      const ta = typeOrder[a.card.type] ?? 99;
      const tb = typeOrder[b.card.type] ?? 99;
      if (ta !== tb) return ta - tb;
      return (a.card.displayId || a.card.id).localeCompare(b.card.displayId || b.card.id, undefined, { numeric: true });
    });
  }, [deckEntries]);

  const dm = isDarkMode;

  return (
    <View style={{ flex: 1, backgroundColor: dm ? '#0f172a' : '#f0f2f5' }}>
      {/* ====== Toolbar ====== */}
      <View style={{
        backgroundColor: dm ? '#1e293b' : '#ffffff',
        borderBottomWidth: 1, borderBottomColor: dm ? '#334155' : '#e2e8f0',
        paddingHorizontal: isMobile ? 12 : 20, paddingVertical: 10,
        flexDirection: 'row', alignItems: 'center', flexWrap: 'wrap', gap: 10,
      }}>
        {/* Counter */}
        <View style={{ flexDirection: 'row', alignItems: 'center', gap: 6 }}>
          <Text style={{ fontSize: 20, fontWeight: '900', color: totalCards === 50 ? '#10b981' : totalCards > 50 ? '#ef4444' : dm ? '#f8fafc' : '#1e293b' }}>
            {totalCards}/50
          </Text>
          {colorsInDeck.length > 0 && (
            <Text style={{ fontSize: 14 }}>
              {colorsInDeck.map(c => colorEmoji[c] || '⬜').join('')}
              {' '}{colorsInDeck.length}色
            </Text>
          )}
        </View>

        {/* Validation toggle */}
        <TouchableOpacity
          style={{
            paddingHorizontal: 10, paddingVertical: 5, borderRadius: 12,
            backgroundColor: validationEnabled ? (dm ? '#10b981' : '#059669') : (dm ? '#334155' : '#e2e8f0'),
          }}
          onPress={() => setValidationEnabled(!validationEnabled)}
        >
          <Text style={{ fontSize: 11, fontWeight: 'bold', color: validationEnabled ? '#fff' : (dm ? '#94a3b8' : '#64748b') }}>
            {validationEnabled ? '☑ 驗證' : '☐ 驗證'}
          </Text>
        </TouchableOpacity>

        {/* Export button */}
        <TouchableOpacity
          style={{ paddingHorizontal: 10, paddingVertical: 5, borderRadius: 12, backgroundColor: dm ? '#334155' : '#e2e8f0' }}
          onPress={handleExport}
          disabled={totalCards === 0}
        >
          <Text style={{ fontSize: 11, fontWeight: 'bold', color: totalCards === 0 ? (dm ? '#475569' : '#94a3b8') : (dm ? '#f8fafc' : '#1e293b') }}>
            📸 截圖
          </Text>
        </TouchableOpacity>

        {/* Clear */}
        <TouchableOpacity
          style={{ paddingHorizontal: 10, paddingVertical: 5, borderRadius: 12, backgroundColor: '#ef4444' }}
          onPress={clearDeck}
        >
          <Text style={{ fontSize: 11, fontWeight: 'bold', color: '#fff' }}>清空</Text>
        </TouchableOpacity>

        {/* Close */}
        <TouchableOpacity
          style={{ marginLeft: 'auto', paddingHorizontal: 12, paddingVertical: 5, borderRadius: 12, backgroundColor: dm ? '#334155' : '#e2e8f0' }}
          onPress={onClose}
        >
          <Text style={{ fontSize: 11, fontWeight: 'bold', color: dm ? '#f8fafc' : '#1e293b' }}>✕ 返回</Text>
        </TouchableOpacity>
      </View>

      {/* ====== Violations ====== */}
      {violations.length > 0 && (
        <View style={{ backgroundColor: '#fef2f2', borderBottomWidth: 1, borderBottomColor: '#fecaca', paddingHorizontal: 16, paddingVertical: 8 }}>
          {violations.map((v, i) => (
            <Text key={i} style={{ fontSize: 12, color: '#dc2626', fontWeight: 'bold' }}>⚠️ {v}</Text>
          ))}
        </View>
      )}

      {/* ====== Main Content ====== */}
      <View style={{ flex: 1, flexDirection: isWide ? 'row' : 'column' }}>
        
        {/* ====== Deck Preview ====== */}
        <View style={{
          width: isWide ? '40%' : '100%',
          height: isWide ? '100%' : (isMobile ? 200 : 280),
          borderRightWidth: isWide ? 1 : 0,
          borderBottomWidth: isWide ? 0 : 1,
          borderColor: dm ? '#334155' : '#e2e8f0',
          backgroundColor: dm ? '#0f172a' : '#f8fafc',
        }}>
          <View style={{ paddingHorizontal: 12, paddingVertical: 8, borderBottomWidth: 1, borderBottomColor: dm ? '#334155' : '#e2e8f0' }}>
            <Text style={{ fontSize: 13, fontWeight: 'bold', color: dm ? '#94a3b8' : '#64748b' }}>
              牌組 ({totalCards} 張)
            </Text>
          </View>
          <ScrollView contentContainerStyle={{ flexDirection: 'row', flexWrap: 'wrap', padding: 8, gap: 6 }}>
            {sortedDeck.map((entry) => {
              const key = entry.card.displayId || entry.card.id;
              const imgKey = entry.card.id;
              const colorBar = { Blue: '#0070b9', Green: '#63a63d', Red: '#be0453', Purple: '#744b92', White: '#94a3b8' };
              return (
                <TouchableOpacity
                  key={key}
                  style={{
                    width: deckCardSize, 
                    borderRadius: 6, overflow: 'hidden',
                    borderWidth: 2, borderColor: colorBar[entry.card.color] || (dm ? '#475569' : '#cbd5e1'),
                    backgroundColor: dm ? '#1e293b' : '#fff',
                  }}
                  onPress={() => removeCard(key)}
                  onLongPress={() => removeAll(key)}
                  activeOpacity={0.7}
                >
                  <View style={{ width: '100%', height: deckCardSize * 1.2, backgroundColor: dm ? '#334155' : '#eaeaea' }}>
                    {cardImages[imgKey] ? (
                      <Image source={{ uri: cardImages[imgKey] }} style={{ width: '100%', height: '100%' }} resizeMode="cover" />
                    ) : (
                      <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center' }}>
                        <Text style={{ fontSize: 8, color: '#999' }}>No img</Text>
                      </View>
                    )}
                    {/* Count badge */}
                    <View style={{
                      position: 'absolute', top: 2, right: 2,
                      backgroundColor: 'rgba(0,0,0,0.75)', borderRadius: 8,
                      width: 18, height: 18, justifyContent: 'center', alignItems: 'center',
                    }}>
                      <Text style={{ fontSize: 10, fontWeight: '900', color: '#fff' }}>×{entry.count}</Text>
                    </View>
                  </View>
                  <Text style={{ fontSize: 8, fontWeight: 'bold', color: dm ? '#cbd5e1' : '#374151', paddingHorizontal: 3, paddingVertical: 2 }} numberOfLines={1}>
                    {entry.card[`name_${language}`] || key}
                  </Text>
                </TouchableOpacity>
              );
            })}
            {totalCards === 0 && (
              <Text style={{ fontSize: 13, color: dm ? '#475569' : '#94a3b8', padding: 20 }}>
                點擊下方卡牌加入牌組
              </Text>
            )}
          </ScrollView>
        </View>

        {/* ====== Card Pool ====== */}
        <View style={{ flex: 1 }}>
          {/* Mini search */}
          <View style={{
            flexDirection: 'row', alignItems: 'center', paddingHorizontal: 12, paddingVertical: 8, gap: 8,
            borderBottomWidth: 1, borderBottomColor: dm ? '#334155' : '#e2e8f0',
            backgroundColor: dm ? '#1e293b' : '#fff',
          }}>
            <TextInput
              style={{
                flex: 1, height: 34, backgroundColor: dm ? '#0f172a' : '#f1f5f9',
                borderRadius: 17, paddingHorizontal: 14, fontSize: 13,
                color: dm ? '#f8fafc' : '#1e293b', borderWidth: 1,
                borderColor: dm ? '#334155' : '#e2e8f0',
              }}
              placeholder="搜尋卡牌名稱或編號..."
              placeholderTextColor={dm ? '#64748b' : '#94a3b8'}
              value={searchText}
              onChangeText={setSearchText}
            />
            {searchText !== '' && (
              <TouchableOpacity onPress={() => setSearchText('')}>
                <Text style={{ fontSize: 16, color: dm ? '#94a3b8' : '#64748b' }}>✕</Text>
              </TouchableOpacity>
            )}
            <Text style={{ fontSize: 11, color: dm ? '#64748b' : '#94a3b8' }}>
              {availableCards.length} 張
            </Text>
          </View>

          <FlatList
            data={availableCards}
            keyExtractor={(item) => item.id}
            numColumns={poolColumns}
            key={poolColumns}
            contentContainerStyle={{ padding: 8 }}
            renderItem={({ item }) => {
              const key = item.displayId || item.id;
              const inDeck = deckMap.get(key);
              const count = inDeck ? inDeck.count : 0;
              const isMaxed = validationEnabled && count >= 4;
              const imgSrc = cardImages[item.id];
              const colorBar = { Blue: '#0070b9', Green: '#63a63d', Red: '#be0453', Purple: '#744b92', White: '#94a3b8' };

              return (
                <TouchableOpacity
                  style={{
                    width: poolCardWidth, margin: 4, borderRadius: 6, overflow: 'hidden',
                    backgroundColor: dm ? '#1e293b' : '#fff',
                    opacity: isMaxed ? 0.4 : 1,
                    borderWidth: count > 0 ? 2 : 1,
                    borderColor: count > 0 ? '#10b981' : (dm ? '#334155' : '#e2e8f0'),
                  }}
                  onPress={() => addCard(item)}
                  activeOpacity={0.7}
                  disabled={isMaxed && validationEnabled}
                >
                  <View style={{ width: '100%', height: poolCardWidth * 1.39, backgroundColor: dm ? '#334155' : '#eaeaea', position: 'relative' }}>
                    {imgSrc ? (
                      <Image source={{ uri: imgSrc }} style={{ width: '100%', height: '100%' }} resizeMode="cover" />
                    ) : (
                      <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center' }}>
                        <Text style={{ fontSize: 9, color: '#999' }}>圖片準備中</Text>
                      </View>
                    )}
                    {/* Color bar */}
                    <View style={{ position: 'absolute', bottom: 0, left: 0, right: 0, height: 3, backgroundColor: colorBar[item.color] || 'transparent' }} />
                    {/* Count overlay */}
                    {count > 0 && (
                      <View style={{
                        position: 'absolute', top: 4, right: 4,
                        backgroundColor: '#10b981', borderRadius: 10,
                        width: 22, height: 22, justifyContent: 'center', alignItems: 'center',
                      }}>
                        <Text style={{ fontSize: 11, fontWeight: '900', color: '#fff' }}>×{count}</Text>
                      </View>
                    )}
                  </View>
                  <View style={{ padding: 4, backgroundColor: dm ? '#1e293b' : '#fff' }}>
                    <Text style={{ fontSize: 9, color: dm ? '#64748b' : '#94a3b8', fontWeight: 'bold' }} numberOfLines={1}>
                      {item.displayId || item.id}
                    </Text>
                    <Text style={{ fontSize: 10, fontWeight: 'bold', color: dm ? '#cbd5e1' : '#374151' }} numberOfLines={1}>
                      {item[`name_${language}`] || '名稱未定'}
                    </Text>
                  </View>
                </TouchableOpacity>
              );
            }}
          />
        </View>
      </View>

      {/* ====== Export View (hidden, rendered for screenshot) ====== */}
      {showExport && (
        <View style={{ position: 'absolute', left: -9999, top: 0 }}>
          <div id="deck-export-area" style={{
            width: 800, padding: 24,
            backgroundColor: isDarkMode ? '#0f172a' : '#ffffff',
            fontFamily: 'sans-serif',
          }}>
            <div style={{ marginBottom: 16, borderBottom: `2px solid ${dm ? '#334155' : '#e2e8f0'}`, paddingBottom: 12 }}>
              <div style={{ fontSize: 20, fontWeight: '900', color: dm ? '#f8fafc' : '#1e293b' }}>
                GCG 牌組 — {totalCards}/50 張 {colorsInDeck.map(c => colorEmoji[c] || '').join(' ')}
              </div>
              <div style={{ fontSize: 11, color: dm ? '#64748b' : '#94a3b8', marginTop: 4 }}>
                gcg.flcdesu.com
              </div>
            </div>
            <div style={{ display: 'flex', flexWrap: 'wrap', gap: 8 }}>
              {sortedDeck.map((entry) => {
                const key = entry.card.displayId || entry.card.id;
                const imgSrc = cardImages[entry.card.id];
                const colorBar = { Blue: '#0070b9', Green: '#63a63d', Red: '#be0453', Purple: '#744b92', White: '#94a3b8' };
                return (
                  <div key={key} style={{
                    width: 100, borderRadius: 6, overflow: 'hidden',
                    border: `2px solid ${colorBar[entry.card.color] || '#cbd5e1'}`,
                    backgroundColor: dm ? '#1e293b' : '#fff',
                  }}>
                    <div style={{ position: 'relative', width: 100, height: 139 }}>
                      {imgSrc && <img src={imgSrc} style={{ width: '100%', height: '100%', objectFit: 'cover' }} crossOrigin="anonymous" />}
                      <div style={{
                        position: 'absolute', top: 3, right: 3,
                        backgroundColor: 'rgba(0,0,0,0.8)', borderRadius: 8,
                        width: 22, height: 22, display: 'flex', justifyContent: 'center', alignItems: 'center',
                        fontSize: 11, fontWeight: '900', color: '#fff',
                      }}>×{entry.count}</div>
                    </div>
                    <div style={{ padding: '3px 4px', fontSize: 8, fontWeight: 'bold', color: dm ? '#94a3b8' : '#64748b' }}>
                      {key}
                    </div>
                    <div style={{ padding: '0 4px 4px', fontSize: 9, fontWeight: 'bold', color: dm ? '#cbd5e1' : '#374151', whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }}>
                      {entry.card[`name_${language}`] || key}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </View>
      )}
    </View>
  );
};

export default DeckBuilder;
